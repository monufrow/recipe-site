<%- include('../partials/header', { title: recipe.name }) %>

<div class="card">
    <h1><%= recipe.name %></h1>
    <p><strong>Protein:</strong> <%= recipe.protein_type %></p>
    <a class="btn-secondary" href="/recipes/<%= recipe.id %>/edit">Edit</a>
</div>

<div class="card">
    <h2>Ingredients</h2>
    <ul>
        <% ingredients.forEach(ingredient => { %>
            <li class="tooltip">
                <%= ingredient.name %>
                <span class="tooltiptext">
                    <%= ingredient.info %>
                </span>
            </li>
        <% }) %>
    </ul>
</div>

<div class="card">
    <h2>Instructions</h2>
    <p><%= recipe.instructions %></p>
</div>

<a href="/recipes">← Back to Recipes</a>

<%- include('../partials/footer') %>