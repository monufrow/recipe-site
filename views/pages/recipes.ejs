<%- include('../partials/header', { title: 'Recipes' }) %>

<h1>Recipes by Protein Type</h1>

<% for (let protein in groupedRecipes) { %>
    <h2><%= protein %></h2>

    <% groupedRecipes[protein].forEach(recipe => { %>
        <div class="card">
            <a href="/recipes/<%= recipe.id %>">
                <strong><%= recipe.name %></strong>
            </a>
        </div>
    <% }) %>
<% } %>

<%- include('../partials/footer') %>