<!DOCTYPE html>
<html>
<head>
    <title>Recipe Listing</title>
</head>
<body>
    <a href="/recipes/add">Add New Recipe</a>

<h1>Recipes by Protein Type</h1>

<% for (let protein in groupedRecipes) { %>
    <h2><%= protein %></h2>
    <ul>
        <% groupedRecipes[protein].forEach(recipe => { %>
            <li>
                <a href="/recipes/<%= recipe.id %>">
                    <%= recipe.name %>
                </a>
            </li>
        <% }) %>
    </ul>
<% } %>

</body>
</html>